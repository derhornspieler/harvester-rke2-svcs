# Environment configuration for deploy scripts (all bundles).
# Copy to .env and fill in all values before running any deploy script.
# Scripts validate at startup and fail with a list of missing vars.
#
# Passwords seed Vault on first deploy via vault_get_or_generate().
# Subsequent runs read from Vault — .env values are only used if Vault is empty.

# --- Core ---
DOMAIN=""
ORG=""
NAME_CONSTRAINT_DNS=""  # optional, comma-separated (e.g. "tiger.net"); omit to skip x509 name constraints
VAULT_INIT_FILE="${SCRIPT_DIR}/../vault-init.json"
ROOT_CA_CERT="${SCRIPT_DIR}/../services/pki/roots/root-ca.pem"
ROOT_CA_KEY=""
export KUBECONFIG=""
TRAEFIK_LB_IP=""

# --- Helm: Bundle 1 (PKI & Secrets) ---
HELM_CHART_CERTMANAGER="jetstack/cert-manager"
HELM_REPO_CERTMANAGER="https://charts.jetstack.io"
HELM_VERSION_CERTMANAGER=""

HELM_CHART_VAULT="hashicorp/vault"
HELM_REPO_VAULT="https://helm.releases.hashicorp.com"
HELM_VERSION_VAULT=""

HELM_CHART_ESO="external-secrets/external-secrets"
HELM_REPO_ESO="https://charts.external-secrets.io"
HELM_VERSION_ESO=""

# --- Helm: Bundle 2 (Identity) ---
HELM_CHART_CNPG="cnpg/cloudnative-pg"
HELM_REPO_CNPG="https://cloudnative-pg.github.io/charts"
HELM_VERSION_CNPG=""

# --- Helm: Bundle 3 (Monitoring) ---
HELM_CHART_PROMETHEUS_STACK="prometheus-community/kube-prometheus-stack"
HELM_REPO_PROMETHEUS_STACK="https://prometheus-community.github.io/helm-charts"
HELM_VERSION_PROMETHEUS_STACK=""

# --- Helm: Bundle 4 (Harbor) ---
HELM_CHART_HARBOR="goharbor/harbor"
HELM_REPO_HARBOR="https://helm.goharbor.io"
HELM_VERSION_HARBOR=""

# --- Helm: Bundle 5 (GitOps — OCI, no HELM_REPO needed) ---
HELM_CHART_ARGOCD="oci://ghcr.io/argoproj/argo-helm/argo-cd"
HELM_CHART_ROLLOUTS="oci://ghcr.io/argoproj/argo-helm/argo-rollouts"
HELM_CHART_WORKFLOWS="oci://ghcr.io/argoproj/argo-helm/argo-workflows"
HELM_VERSION_ARGOCD=""
HELM_VERSION_ARGO_ROLLOUTS=""
HELM_VERSION_ARGO_WORKFLOWS=""

# --- Helm: Bundle 6 (Git & CI) ---
HELM_CHART_GITLAB="gitlab/gitlab"
HELM_CHART_RUNNER="gitlab/gitlab-runner"
HELM_REPO_GITLAB="https://charts.gitlab.io"
HELM_VERSION_GITLAB=""
HELM_VERSION_GITLAB_RUNNER=""

# --- Bundle 2: Identity (Keycloak + MinIO) ---
KC_REALM="platform"
LDAP_CA_CERT=""  # optional, path to PEM-encoded private CA cert for LDAPS user federation
PLATFORM_ADMIN_USER=""
PLATFORM_ADMIN_EMAIL=""
KC_ADMIN_PASSWORD=""
KEYCLOAK_DB_PASSWORD=""
KEYCLOAK_BOOTSTRAP_CLIENT_SECRET=""

# --- Bundle 3: Monitoring ---
GRAFANA_ADMIN_PASSWORD=""
OAUTH2_REDIS_SENTINEL=""

# --- Bundle 4: Harbor ---
HARBOR_ADMIN_PASSWORD=""
HARBOR_DB_PASSWORD=""
HARBOR_REDIS_PASSWORD=""
HARBOR_MINIO_SECRET_KEY=""

# --- Bundle 5: GitOps (Argo) ---
ARGO_ROLLOUTS_PLUGIN_URL=""

# --- Bundle 6: Git & CI (GitLab) ---
GITLAB_ROOT_PASSWORD=""
GITLAB_REDIS_PASSWORD=""
