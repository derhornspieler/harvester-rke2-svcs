# deploy-pki-secrets.sh environment configuration
# Copy to .env and fill in values before running.

# Domain configuration (required)
DOMAIN="example.com"
# Auto-derived (override if needed):
# DOMAIN_DASHED="example-com"
# DOMAIN_DOT="example-dot-com"

# Vault init output file (created during Phase 2)
VAULT_INIT_FILE="${SCRIPT_DIR}/../vault-init.json"

# Root CA paths (required for Phase 3: PKI setup)
ROOT_CA_CERT="${SCRIPT_DIR}/../services/pki/roots/root-ca.pem"
ROOT_CA_KEY=""  # Path to offline Root CA key — NOT committed to git

# Private CA certificate path — set this if providing your own PKI root CA.
# Used by deploy scripts to create vault-root-ca ConfigMaps in each namespace.
# PRIVATE_CA_CERT=""

# Organization name (used in Vault intermediate CA subject)
ORG="My Organization"

# Root CA nameConstraints DNS (used by generate-ca.sh when creating a new Root CA)
NAME_CONSTRAINT_DNS="example.com"

# Helm chart sources (override for OCI registries like Harbor)
# Default: upstream repos. Set to oci:// paths for private registries.
# HELM_CHART_CERTMANAGER="oci://harbor.example.com/charts/cert-manager"
# HELM_REPO_CERTMANAGER="oci://harbor.example.com/charts"
# HELM_CHART_VAULT="oci://harbor.example.com/charts/vault"
# HELM_REPO_VAULT="oci://harbor.example.com/charts"
# HELM_CHART_ESO="oci://harbor.example.com/charts/external-secrets"
# HELM_REPO_ESO="oci://harbor.example.com/charts"

# Grafana admin password (required for monitoring bundle)
GRAFANA_ADMIN_PASSWORD=""

# Basic-auth credentials for Prometheus / Alertmanager ingress (required for monitoring bundle)
PROM_BASIC_AUTH_PASS=""
AM_BASIC_AUTH_PASS=""
# PROM_BASIC_AUTH_USER="admin"   # override username (default: admin)
# AM_BASIC_AUTH_USER="admin"     # override username (default: admin)

# Prometheus stack Helm chart (override for OCI)
# HELM_CHART_PROMETHEUS_STACK="oci://harbor.example.com/charts/kube-prometheus-stack"
# HELM_REPO_PROMETHEUS_STACK="oci://harbor.example.com/charts"

# Harbor passwords (required for Harbor bundle)
HARBOR_ADMIN_PASSWORD=""
HARBOR_DB_PASSWORD=""
HARBOR_REDIS_PASSWORD=""
HARBOR_MINIO_SECRET_KEY=""

# Harbor Helm chart (OCI by default)
# HELM_CHART_HARBOR="oci://registry-1.docker.io/goharbor/harbor-helm"

# Keycloak passwords (required for Identity bundle)
KC_ADMIN_PASSWORD=""
KEYCLOAK_DB_PASSWORD=""
KC_REALM="platform"
KEYCLOAK_BOOTSTRAP_CLIENT_SECRET=""
# KC_ADMIN_USER="admin"   # override bootstrap admin username (default: admin)

# CNPG operator Helm chart (used by deploy-keycloak.sh Phase 1)
# HELM_CHART_CNPG="cnpg/cloudnative-pg"
# HELM_REPO_CNPG="https://cloudnative-pg.github.io/charts"

# Platform admin user (replaces legacy admin-breakglass)
PLATFORM_ADMIN_USER="admin.user"
PLATFORM_ADMIN_EMAIL=""    # defaults to <PLATFORM_ADMIN_USER>@<DOMAIN>
PLATFORM_ADMIN_PASSWORD="" # auto-generated if not set

# OAuth2-proxy Redis Sentinel connection URLs (required for OAuth2-proxy session store)
# Format: redis://:<password>@<sentinel1>:26379,redis://:<password>@<sentinel2>:26379
OAUTH2_REDIS_SENTINEL=""

# Argo GitOps passwords (required for GitOps bundle)
ARGO_BASIC_AUTH_PASS=""
WORKFLOWS_BASIC_AUTH_PASS=""

# Argo Helm charts (OCI by default)
# HELM_CHART_ARGOCD="oci://ghcr.io/argoproj/argo-helm/argo-cd"
# HELM_CHART_ROLLOUTS="oci://ghcr.io/argoproj/argo-helm/argo-rollouts"
# HELM_CHART_WORKFLOWS="oci://ghcr.io/argoproj/argo-helm/argo-workflows"

# Argo Rollouts Gateway API plugin URL (override if using local mirror)
# In airgapped environments, download the binary and serve it from an internal HTTP server
# or place it on a shared volume. The URL must be reachable from the rollouts controller pod.
# ARGO_ROLLOUTS_PLUGIN_URL="https://github.com/argoproj-labs/rollouts-plugin-trafficrouter-gatewayapi/releases/download/v0.6.0/gateway-api-plugin-linux-amd64"

# GitLab passwords (required for GitLab bundle)
GITLAB_ROOT_PASSWORD=""
GITLAB_REDIS_PASSWORD=""

# GitLab Helm chart
# HELM_CHART_GITLAB="gitlab/gitlab"
# HELM_REPO_GITLAB="https://charts.gitlab.io"
# HELM_CHART_RUNNER="gitlab/gitlab-runner"

# Kubeconfig (optional — uses current context if not set)
# export KUBECONFIG="/path/to/kubeconfig"

# Prometheus URL for storage-autoscaler (auto-detected after Bundle 2 deploy)
# PROMETHEUS_ADDR="http://prometheus.monitoring.svc:9090"

## Airgap / Private Registry -----------------------------------------------
# Override Helm chart sources for disconnected environments.
# All HELM_CHART_* and HELM_REPO_* variables accept oci:// paths.
#
# Example (Harbor pull-through cache):
#   HELM_CHART_CERTMANAGER="oci://harbor.example.com/charts/cert-manager"
#   HELM_REPO_CERTMANAGER="oci://harbor.example.com/charts"
#   HELM_CHART_VAULT="oci://harbor.example.com/charts/vault"
#   HELM_REPO_VAULT="oci://harbor.example.com/charts"
#   HELM_CHART_ESO="oci://harbor.example.com/charts/external-secrets"
#   HELM_REPO_ESO="oci://harbor.example.com/charts"
#   HELM_CHART_CNPG="oci://harbor.example.com/charts/cloudnative-pg"
#   HELM_REPO_CNPG="oci://harbor.example.com/charts"
#   HELM_CHART_PROMETHEUS_STACK="oci://harbor.example.com/charts/kube-prometheus-stack"
#   HELM_REPO_PROMETHEUS_STACK="oci://harbor.example.com/charts"
#   HELM_CHART_HARBOR="oci://harbor.example.com/charts/harbor-helm"
#   HELM_REPO_HARBOR="oci://harbor.example.com/charts"
#   HELM_CHART_ARGOCD="oci://harbor.example.com/charts/argo-cd"
#   HELM_CHART_ROLLOUTS="oci://harbor.example.com/charts/argo-rollouts"
#   HELM_CHART_WORKFLOWS="oci://harbor.example.com/charts/argo-workflows"
#   HELM_CHART_GITLAB="oci://harbor.example.com/charts/gitlab"
#   HELM_REPO_GITLAB="oci://harbor.example.com/charts"
#   HELM_CHART_RUNNER="oci://harbor.example.com/charts/gitlab-runner"
#
# For ARGO_ROLLOUTS_PLUGIN_URL, mirror the binary to an internal HTTP server.
