#!/usr/bin/env bash
# fleet-gitops/.env.example — Complete environment configuration
# Copy to .env and fill in values for your environment
# Used by: deploy-fleet-helmops.sh, push-bundles.sh, push-charts.sh, render-templates.sh
#
# SECURITY: .env is gitignored. Never commit credentials.

###############################################################################
# 1. CREDENTIALS — Required for deployment
###############################################################################

# Rancher management cluster API
RANCHER_URL=https://rancher.example.com
RANCHER_TOKEN=token-xxxxx:yyyyyyyyyyyyyyyyyyyyyy

# Harbor OCI registry credentials (for chart/bundle push)
HARBOR_USER=admin
HARBOR_PASS=changeme

# GitLab Enterprise license activation code (stored in Vault)
GITLAB_LICENSE=""

###############################################################################
# 2. CORE INFRASTRUCTURE — Must change per environment
###############################################################################

# Base domain for all services (keycloak.<DOMAIN>, gitlab.<DOMAIN>, etc.)
DOMAIN=example.com

# Harbor registry hostname (OCI chart source + pull-through cache)
HARBOR_HOST=harbor.dev.example.com

# Fleet target cluster name (Rancher downstream cluster)
FLEET_TARGET_CLUSTER=rke2-prod

# Fleet namespace on management cluster
FLEET_NAMESPACE=fleet-default

# Traefik load balancer IP (MetalLB / DHCP reservation)
TRAEFIK_LB_IP=192.168.1.100

# DNS server for ExternalDNS RFC2136 dynamic updates
DNS_SERVER_IP=<DNS_SERVER_IP>

# DNS zone for ExternalDNS
DNS_ZONE=example.com

# TSIG key name for ExternalDNS RFC2136 authentication
TSIG_KEY_NAME=external-dns-key

# S3/MinIO region (usually us-east-1 for MinIO)
S3_REGION=us-east-1

###############################################################################
# 2b. GOLDEN IMAGE WATCHER — Credentials for upstream image polling
###############################################################################

# GitLab user and project access token for the golden-image-watcher
# (Argo CronWorkflow clones and pushes to this repo when upstream images change)
GOLDEN_IMAGE_GITLAB_USER=""
GOLDEN_IMAGE_GITLAB_TOKEN=""
GOLDEN_IMAGE_GITLAB_REPO_URL=gitlab.example.com/infrastructure/harvester-golden-images.git

# Path to Harvester kubeconfig (for the golden-image-builder runner)
# The runner uses this to orchestrate builds on the Harvester cluster.
HARVESTER_KUBECONFIG_PATH=""

# Kubernetes storage class name
STORAGE_CLASS=longhorn

# Gateway class name (traefik, nginx, istio, etc.)
GATEWAY_CLASS=traefik

###############################################################################
# 3. IDENTITY & OIDC
###############################################################################

# Keycloak OIDC realm name
KEYCLOAK_REALM=platform

# Platform admin username (created in Keycloak + promoted in GitLab)
PLATFORM_ADMIN_USER=admin.user
PLATFORM_ADMIN_EMAIL=admin@example.com

# RBAC group names (must match Keycloak groups)
RBAC_GROUP_ADMINS=platform-admins
RBAC_GROUP_INFRA=infra-engineers
RBAC_GROUP_NETWORK=network-engineers
RBAC_GROUP_SENIOR_DEVS=senior-developers
RBAC_GROUP_DEVS=developers

###############################################################################
# 4. SERVICE FQDNs — Derived from DOMAIN, override only if needed
###############################################################################

# These default to <service>.${DOMAIN} if not set explicitly.
# Override for non-standard naming (e.g., harbor uses dev. subdomain).
# Override for non-standard Harbor FQDN (internal cluster Harbor vs Fleet OCI Harbor)
HARBOR_FQDN=harbor.dev.example.com

# Rancher management cluster FQDN (for Keycloak OIDC redirect)
# RANCHER_FQDN=rancher.hvst-vip.example.com

# Uncomment to override any service FQDN (defaults to <service>.${DOMAIN}):
# KEYCLOAK_FQDN=keycloak.${DOMAIN}
# VAULT_FQDN=vault.${DOMAIN}
# GITLAB_FQDN=gitlab.${DOMAIN}
# KAS_FQDN=kas.${DOMAIN}
# ARGOCD_FQDN=argo.${DOMAIN}
# ROLLOUTS_FQDN=rollouts.${DOMAIN}
# WORKFLOWS_FQDN=workflows.${DOMAIN}
# GRAFANA_FQDN=grafana.${DOMAIN}
# PROMETHEUS_FQDN=prometheus.${DOMAIN}
# ALERTMANAGER_FQDN=alertmanager.${DOMAIN}
# HUBBLE_FQDN=hubble.${DOMAIN}
# TRAEFIK_FQDN=traefik.${DOMAIN}

###############################################################################
# 5. INTERNAL SERVICE URLs — Change only for non-standard namespaces
###############################################################################

# Vault cluster-internal URL
VAULT_INTERNAL_URL=http://vault.vault.svc.cluster.local:8200

# MinIO cluster-internal URL and hostname
MINIO_INTERNAL_URL=http://minio.minio.svc.cluster.local:9000
MINIO_INTERNAL_HOST=minio.minio.svc.cluster.local

# Prometheus cluster-internal URL (for VolumeAutoscaler)
PROMETHEUS_INTERNAL_URL=http://kube-prometheus-stack-prometheus.monitoring.svc.cluster.local:9090

# Loki cluster-internal URL
LOKI_INTERNAL_URL=http://loki.monitoring.svc:3100

# Keycloak cluster-internal URL (for bootstrap jobs)
KEYCLOAK_INTERNAL_URL=http://keycloak.keycloak.svc.cluster.local:8080

###############################################################################
# 6. DATABASE HOSTS — CNPG pooler/cluster endpoints
###############################################################################

# Keycloak PostgreSQL
KEYCLOAK_DB_HOST=keycloak-pg-rw.database.svc.cluster.local
KEYCLOAK_DB_NAME=keycloak

# Grafana PostgreSQL
GRAFANA_DB_HOST=grafana-pg-rw.database.svc.cluster.local:5432
GRAFANA_DB_NAME=grafana

# Harbor PostgreSQL
HARBOR_DB_HOST=harbor-pg-rw.database.svc.cluster.local
HARBOR_DB_NAME=registry

# GitLab PostgreSQL (PgBouncer poolers)
GITLAB_DB_HOST_RW=gitlab-pg-pooler-rw.database.svc.cluster.local
GITLAB_DB_HOST_RO=gitlab-pg-pooler-ro.database.svc.cluster.local
GITLAB_DB_NAME=gitlabhq_production

###############################################################################
# 7. REDIS/VALKEY — Sentinel configuration
###############################################################################

# Sentinel master group name
REDIS_MASTER_NAME=mymaster

# Harbor Redis/Valkey sentinel endpoint
HARBOR_REDIS_SENTINEL=harbor-redis-sentinel.harbor.svc.cluster.local:26379

# GitLab Redis sentinel endpoint
GITLAB_REDIS_SENTINEL=gitlab-redis-sentinel.gitlab.svc.cluster.local

###############################################################################
# 8. VAULT PATHS — Adjust if using different mount points
###############################################################################

# Vault KV engine mount path
VAULT_KV_MOUNT=kv

# Vault PKI intermediate mount path
VAULT_PKI_MOUNT=pki_int

# Vault Kubernetes auth mount path
VAULT_K8S_AUTH_PATH=auth/kubernetes

###############################################################################
# 9. S3/MINIO BUCKETS — Override bucket naming
###############################################################################

MINIO_BUCKET_HARBOR=harbor
MINIO_BUCKET_CNPG_BACKUPS=cnpg-backups
MINIO_BUCKET_GITLAB_LFS=gitlab-lfs
MINIO_BUCKET_GITLAB_ARTIFACTS=gitlab-artifacts
MINIO_BUCKET_GITLAB_UPLOADS=gitlab-uploads
MINIO_BUCKET_GITLAB_PACKAGES=gitlab-packages
MINIO_BUCKET_GITLAB_PAGES=gitlab-pages
MINIO_BUCKET_GITLAB_MR_DIFFS=gitlab-mr-diffs
MINIO_BUCKET_GITLAB_TERRAFORM=gitlab-terraform
MINIO_BUCKET_GITLAB_CI_SECURE_FILES=gitlab-ci-secure-files
MINIO_BUCKET_GITLAB_DEPENDENCY_PROXY=gitlab-dependency-proxy

###############################################################################
# 10. CONTAINER IMAGE OVERRIDES — For air-gapped / pull-through cache
###############################################################################

# Base images (used in Jobs and custom operators)
IMAGE_ALPINE_K8S=docker.io/alpine/k8s:1.32.4
IMAGE_CURL=curlimages/curl:8.12.1

# Identity
IMAGE_KEYCLOAK=quay.io/keycloak/keycloak:26.0.8

# Databases
IMAGE_POSTGRESQL_17=ghcr.io/cloudnative-pg/postgresql:17.6
IMAGE_POSTGRESQL_16=ghcr.io/cloudnative-pg/postgresql:16.6

# Redis / Valkey
IMAGE_REDIS=quay.io/opstree/redis:v7.0.15
IMAGE_REDIS_SENTINEL=quay.io/opstree/redis-sentinel:v7.0.15
IMAGE_REDIS_EXPORTER=oliver006/redis_exporter:v1.66.0

# Storage
IMAGE_MINIO=quay.io/minio/minio:RELEASE.2024-11-07T00-52-20Z
IMAGE_MINIO_MC=quay.io/minio/mc:RELEASE.2025-08-13T08-35-41Z

# Monitoring
IMAGE_LOKI=docker.io/grafana/loki:3.4.6
IMAGE_ALLOY=docker.io/grafana/alloy:v1.6.1

# Auth proxy (used by 8 services)
IMAGE_OAUTH2_PROXY=quay.io/oauth2-proxy/oauth2-proxy:v7.8.1

# Custom operators
IMAGE_NODE_LABELER=harbor.example.com/library/node-labeler:v0.2.0
IMAGE_STORAGE_AUTOSCALER=harbor.example.com/library/storage-autoscaler:v0.2.0
IMAGE_CLUSTER_AUTOSCALER=registry.k8s.io/autoscaling/cluster-autoscaler:v1.34.3

# Cluster autoscaler scale-down behavior (conservative defaults)
AUTOSCALER_SCALE_DOWN_DELAY_AFTER_ADD=15m0s
AUTOSCALER_SCALE_DOWN_DELAY_AFTER_DELETE=30m0s
AUTOSCALER_SCALE_DOWN_UNNEEDED_TIME=30m0s
AUTOSCALER_SCALE_DOWN_UTILIZATION_THRESHOLD=0.5

# Vault
IMAGE_VAULT=hashicorp/vault:1.21.2

# ArgoCD dependencies
IMAGE_VALKEY=valkey/valkey:8-alpine
IMAGE_HAPROXY=docker.io/library/haproxy:2.9.4-alpine

###############################################################################
# 11. HELM CHART VERSIONS — Single source of truth
###############################################################################
# Used by both push-charts.sh (pull upstream) and deploy-fleet-helmops.sh (deploy)

CHART_VER_CERT_MANAGER=v1.19.4
CHART_VER_VAULT=0.32.0
CHART_VER_EXTERNAL_SECRETS=2.0.1
CHART_VER_CNPG=0.27.1
CHART_VER_REDIS_OPERATOR=0.23.0
CHART_VER_EXTERNAL_DNS=1.16.1
CHART_VER_PROMETHEUS_CRDS=27.0.0
CHART_VER_PROMETHEUS_STACK=82.10.0
CHART_VER_HARBOR=1.18.2
CHART_VER_ARGOCD=9.4.7
CHART_VER_ARGO_ROLLOUTS=2.40.6
CHART_VER_ARGO_WORKFLOWS=0.47.4
CHART_VER_GITLAB=9.9.2
CHART_VER_GITLAB_RUNNER=0.86.0

###############################################################################
# 12. UPSTREAM HELM REPOS — For push-charts.sh to pull from
###############################################################################

HELM_REPO_CERT_MANAGER=https://charts.jetstack.io
HELM_REPO_VAULT=https://helm.releases.hashicorp.com
HELM_REPO_EXTERNAL_SECRETS=https://charts.external-secrets.io
HELM_REPO_CNPG=https://cloudnative-pg.github.io/charts
HELM_REPO_PROMETHEUS=https://prometheus-community.github.io/helm-charts
HELM_REPO_HARBOR=https://helm.goharbor.io
HELM_REPO_GITLAB=https://charts.gitlab.io
HELM_REPO_REDIS_OPERATOR=https://ot-container-kit.github.io/helm-charts
HELM_REPO_EXTERNAL_DNS=https://kubernetes-sigs.github.io/external-dns

# Argo charts are OCI-native (no Helm repo, pulled via oci://)
OCI_SRC_ARGOCD=oci://ghcr.io/argoproj/argo-helm/argo-cd
OCI_SRC_ARGO_ROLLOUTS=oci://ghcr.io/argoproj/argo-helm/argo-rollouts
OCI_SRC_ARGO_WORKFLOWS=oci://ghcr.io/argoproj/argo-helm/argo-workflows

###############################################################################
# 13. OCI CHART PATH OVERRIDES — Per-chart full OCI URI
###############################################################################
# Override any chart's OCI path to pull from a different registry/project.
# Defaults: oci://${HARBOR_HOST}/helm/<chart-name>
# Example: OCI_CHART_VAULT=oci://harbor.dmz.tiger.net/charts.hashicorp.com/vault
#
# OCI_CHART_PROMETHEUS_CRDS=oci://${HARBOR_HOST}/helm/prometheus-operator-crds
# OCI_CHART_CNPG=oci://${HARBOR_HOST}/helm/cloudnative-pg
# OCI_CHART_REDIS_OPERATOR=oci://${HARBOR_HOST}/helm/redis-operator
# OCI_CHART_CERT_MANAGER=oci://${HARBOR_HOST}/helm/cert-manager
# OCI_CHART_VAULT=oci://${HARBOR_HOST}/helm/vault
# OCI_CHART_EXTERNAL_SECRETS=oci://${HARBOR_HOST}/helm/external-secrets
# OCI_CHART_EXTERNAL_DNS=oci://${HARBOR_HOST}/helm/external-dns
# OCI_CHART_PROMETHEUS_STACK=oci://${HARBOR_HOST}/helm/kube-prometheus-stack
# OCI_CHART_HARBOR=oci://${HARBOR_HOST}/helm/harbor
# OCI_CHART_ARGOCD=oci://${HARBOR_HOST}/helm/argo-cd
# OCI_CHART_ARGO_ROLLOUTS=oci://${HARBOR_HOST}/helm/argo-rollouts
# OCI_CHART_ARGO_WORKFLOWS=oci://${HARBOR_HOST}/helm/argo-workflows
# OCI_CHART_GITLAB=oci://${HARBOR_HOST}/helm/gitlab
# OCI_CHART_GITLAB_RUNNER=oci://${HARBOR_HOST}/helm/gitlab-runner

###############################################################################
# 14. BUNDLE VERSION — Raw manifest OCI artifacts
###############################################################################

# Bump when manifests change, then run push-bundles.sh + deploy-fleet-helmops.sh
BUNDLE_VERSION=1.0.0

###############################################################################
# 14. ROOT CA CERTIFICATE — Path to PEM file (NOT inline)
###############################################################################
# The render script reads this file and injects it into manifests that need it.
# This replaces the 6 inline PEM copies scattered across the codebase.

ROOT_CA_PEM_FILE=./root-ca.pem
